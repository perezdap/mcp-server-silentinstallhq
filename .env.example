# Transport: stdio | sse | streamable-http
SILENTINSTALLHQ_TRANSPORT=streamable-http
SILENTINSTALLHQ_HOST=0.0.0.0
SILENTINSTALLHQ_PORT=8000

# Cache
SILENTINSTALLHQ_CACHE_DIR=./data
SILENTINSTALLHQ_CACHE_TTL_HOURS=24

# Scraping
SILENTINSTALLHQ_BASE_URL=https://silentinstallhq.com
SILENTINSTALLHQ_USER_AGENT=mcp-server-silentinstallhq/0.1.0 (+https://github.com/perezdap/mcp-server-silentinstallhq)
SILENTINSTALLHQ_REQUEST_DELAY_SECONDS=1.0
SILENTINSTALLHQ_REQUEST_TIMEOUT_SECONDS=30
SILENTINSTALLHQ_RESPECT_ROBOTS_TXT=true
SILENTINSTALLHQ_HTTPX_MAX_CONNECTIONS=5
SILENTINSTALLHQ_HTTPX_MAX_KEEPALIVE_CONNECTIONS=2

# Logging
SILENTINSTALLHQ_LOG_LEVEL=INFO